# General
APP_ENV=prod
LOG_LEVEL=INFO
TZ=Europe/Warsaw

# ClickHouse
CH_HOST=clickhouse
CH_PORT=8123
CH_USER=admin
CH_PASSWORD=admin_password
CH_DB=mp_analytics

# ClickHouse read-only user for Metabase (optional)
CH_RO_USER=metabase_ro
CH_RO_PASSWORD=metabase_ro_password

# Redis
REDIS_URL=redis://redis:6379/0

# WB
WB_TOKEN_STATISTICS=...
WB_TOKEN_ANALYTICS=...
# optional: token creation datetime for 180-day expiry reminder
# WB_TOKEN_CREATED_AT=2026-01-15T10:00:00+03:00

# Ozon
OZON_CLIENT_ID=...
OZON_API_KEY=...
# optional perf api key if separate
OZON_PERF_API_KEY=...
# postings schemas to collect (comma separated): fbs,fbo
OZON_POSTINGS_SCHEMAS=fbs,fbo

# Admin API access
ADMIN_API_KEY=change_me

# Telegram
TG_BOT_TOKEN=
TG_CHAT_ID=
