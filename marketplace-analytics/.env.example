# General
STACK_NAME=bormostats
APP_ENV=prod
LOG_LEVEL=INFO
TZ=Europe/Warsaw

# ClickHouse
CH_HOST=clickhouse
CH_PORT=8123
# host-published ClickHouse HTTP port for local bootstrap and tools (loopback only)
CH_HTTP_HOST_PORT=18123
# host-side ClickHouse endpoint for bootstrap and CI runners
BOOTSTRAP_CH_HOST=localhost
BOOTSTRAP_CH_PORT=18123
BOOTSTRAP_CH_ADMIN_USER=bootstrap_admin
BOOTSTRAP_CH_ADMIN_PASSWORD=replace-with-strong-bootstrap-clickhouse-password
CH_USER=analytics_app
CH_PASSWORD=replace-with-strong-clickhouse-password
CH_DB=mp_analytics

# ClickHouse read-only user for Metabase (optional)
CH_RO_USER=
CH_RO_PASSWORD=

# Redis
REDIS_URL=redis://redis:6379/0

# Host-published reverse-proxy and loopback-only service ports
BACKEND_HOST_PORT=18080
BACKEND_TLS_HOST_PORT=18443
METABASE_HOST_PORT=13000
WORKER_METRICS_HOST_PORT=19101
BEAT_METRICS_HOST_PORT=19102
TLS_SERVER_NAME=localhost
TLS_CERT_DAYS=30

# Container resource guardrails (tune for your host)
CLICKHOUSE_MEMORY_LIMIT=2g
CLICKHOUSE_MEMORY_RESERVATION=512m
CLICKHOUSE_CPU_LIMIT=2.0
REDIS_MEMORY_LIMIT=512m
REDIS_MEMORY_RESERVATION=128m
REDIS_CPU_LIMIT=0.5
BACKEND_MEMORY_LIMIT=512m
BACKEND_MEMORY_RESERVATION=128m
BACKEND_CPU_LIMIT=1.0
WORKER_MEMORY_LIMIT=1g
WORKER_MEMORY_RESERVATION=256m
WORKER_CPU_LIMIT=2.0
BEAT_MEMORY_LIMIT=256m
BEAT_MEMORY_RESERVATION=64m
BEAT_CPU_LIMIT=0.5
METABASE_MEMORY_LIMIT=1g
METABASE_MEMORY_RESERVATION=256m
METABASE_CPU_LIMIT=1.0

# WB
WB_TOKEN_STATISTICS=
WB_TOKEN_ANALYTICS=
# optional: token creation datetime for 180-day expiry reminder
# WB_TOKEN_CREATED_AT=2026-01-15T10:00:00+03:00

# Ozon
OZON_CLIENT_ID=
OZON_API_KEY=
# optional perf api key if separate
OZON_PERF_API_KEY=
# postings schemas to collect (comma separated): fbs,fbo
OZON_POSTINGS_SCHEMAS=fbs,fbo

# Admin API access
ADMIN_API_KEY=replace-with-long-random-admin-key

# Telegram
TG_BOT_TOKEN=
TG_CHAT_ID=
