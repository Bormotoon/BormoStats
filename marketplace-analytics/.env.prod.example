# Prod environment template
STACK_NAME=bormostats-prod
APP_ENV=prod
LOG_LEVEL=INFO
TZ=Europe/Warsaw

CH_HOST=clickhouse
CH_PORT=8123
CH_HTTP_HOST_PORT=38123
BOOTSTRAP_CH_HOST=127.0.0.1
BOOTSTRAP_CH_PORT=38123
BOOTSTRAP_CH_ADMIN_USER=bootstrap_admin
BOOTSTRAP_CH_ADMIN_PASSWORD=replace-with-prod-bootstrap-password
CH_USER=analytics_app
CH_PASSWORD=replace-with-prod-clickhouse-password
CH_DB=mp_analytics
CH_RO_USER=
CH_RO_PASSWORD=

REDIS_URL=redis://redis:6379/0

BACKEND_HOST_PORT=38080
BACKEND_TLS_HOST_PORT=38443
METABASE_HOST_PORT=33000
WORKER_METRICS_HOST_PORT=39101
BEAT_METRICS_HOST_PORT=39102
TLS_SERVER_NAME=analytics.example.com
TLS_CERT_DAYS=90

CLICKHOUSE_MEMORY_LIMIT=2g
CLICKHOUSE_MEMORY_RESERVATION=512m
CLICKHOUSE_CPU_LIMIT=2.0
REDIS_MEMORY_LIMIT=512m
REDIS_MEMORY_RESERVATION=128m
REDIS_CPU_LIMIT=0.5
BACKEND_MEMORY_LIMIT=512m
BACKEND_MEMORY_RESERVATION=128m
BACKEND_CPU_LIMIT=1.0
WORKER_MEMORY_LIMIT=1g
WORKER_MEMORY_RESERVATION=256m
WORKER_CPU_LIMIT=2.0
BEAT_MEMORY_LIMIT=256m
BEAT_MEMORY_RESERVATION=64m
BEAT_CPU_LIMIT=0.5
METABASE_MEMORY_LIMIT=1g
METABASE_MEMORY_RESERVATION=256m
METABASE_CPU_LIMIT=1.0

WB_TOKEN_STATISTICS=
WB_TOKEN_ANALYTICS=
OZON_CLIENT_ID=
OZON_API_KEY=
OZON_PERF_API_KEY=
OZON_POSTINGS_SCHEMAS=fbs,fbo
ADMIN_API_KEY=replace-with-prod-admin-key
TG_BOT_TOKEN=
TG_CHAT_ID=
